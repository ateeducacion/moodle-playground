# Local HTTP server
APP_HOST=127.0.0.1
APP_PORT=8080
PYTHON_BIN=python3

# php-wasm / php-cgi-wasm
PHP_WASM_VERSION=0.0.9-alpha-32

# Moodle bootstrap
MOODLE_AVAILABLE_VERSIONS=4.3,4.4
MOODLE_DEFAULT_VERSION=4.4
MOODLE_ASSET_BASE_URL=./vendor/moodle
MOODLE_MANIFEST_URL=./vendor/moodle/4.4/manifest.json
MOODLE_SOURCE_URL_4_3=https://codeload.github.com/moodle/moodle/zip/refs/tags/v4.3.9
MOODLE_SOURCE_URL_4_4=https://codeload.github.com/moodle/moodle/zip/refs/tags/v4.4.5
MOODLE_ADMIN_USER=admin

# Database defaults passed to Moodle config.php
MOODLE_DB_HOST=idb-storage
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=postgres
MOODLE_DB_PASSWORD=postgres
MOODLE_DB_PREFIX=mdl_
